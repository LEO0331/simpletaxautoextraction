rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function validString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function validOptionalString(value, maxLen) {
      return !(value is string) || value.size() <= maxLen;
    }

    function validTaxRecord(data, userId) {
      return data.keys().hasAll([
          'userId',
          'financialYear',
          'propertyId',
          'propertyName',
          'income',
          'expenses',
          'notes',
          'isLocked',
          'parserVersion',
          'lineItems'
        ])
        && data.keys().hasOnly([
          'userId',
          'financialYear',
          'propertyId',
          'propertyName',
          'income',
          'expenses',
          'notes',
          'isLocked',
          'sourceFileName',
          'sourceParser',
          'parserVersion',
          'lineItems',
          'createdAt',
          'updatedAt'
        ])
        && data.userId == userId
        && validString(data.financialYear, 16)
        && validString(data.propertyId, 64)
        && validString(data.propertyName, 120)
        && (data.income is map)
        && (data.expenses is map)
        && (data.notes is string)
        && data.notes.size() <= 2000
        && (data.isLocked is bool)
        && validOptionalString(data.sourceFileName, 255)
        && validOptionalString(data.sourceParser, 120)
        && validString(data.parserVersion, 24)
        && (data.lineItems is list);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /tax_records/{recordId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validTaxRecord(request.resource.data, userId);
      }

      match /settings/{settingId} {
        allow read, write: if isOwner(userId)
          && settingId == "mappings"
          && request.resource.data.income is map
          && request.resource.data.expense is map;
      }

      match /properties/{propertyId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validString(request.resource.data.name, 120);
      }
    }
  }
}
